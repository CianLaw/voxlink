{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "VoxLink",
  "version": "1.0.0",
  "identifier": "com.voxlink.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "VoxLink - 语音输入助手",
      "menuOnLeftClick": false
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      },
      "wix": {
        "language": "zh-CN"
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "./Entitlements.plist"
    },
    "iOS": {
      "minimumSystemVersion": "15.0",
      "developmentTeam": "YOUR_TEAM_ID",
      "provisioningProfile": "./ios/VoxLink.mobileprovision"
    },
    "android": {
      "minSdkVersion": 26,
      "targetSdkVersion": 34
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "global-shortcut": {
      "shortcuts": [
        {
          "modifiers": "Alt",
          "code": "Space",
          "event": "toggle-voxlink"
        }
      ]
    },
    "clipboard-manager": {
      "all": true
    },
    "shell": {
      "open": true
    }
  }
}